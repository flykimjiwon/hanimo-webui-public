{
  "name": "hanimo-webui",
  "version": "0.1.0",
  "description": "hanimo-webui - Open-source self-hosted AI chat, admin runtime, and OpenAI-compatible API",
  "keywords": [
    "ai",
    "chat",
    "self-hosted",
    "open-source",
    "ollama",
    "openai-compatible",
    "nextjs",
    "postgresql",
    "hanimo"
  ],
  "homepage": "https://github.com/flykimjiwon/hanimo-webui-public#readme",
  "bugs": {
    "url": "https://github.com/flykimjiwon/hanimo-webui-public/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flykimjiwon/hanimo-webui-public.git"
  },
  "license": "Apache-2.0",
  "author": "Kim Jiwon (김지원) <flykimjiwun@naver.com> (https://github.com/flykimjiwon)",
  "private": false,
  "scripts": {
    "dev": "node scripts/dev-safe.js",
    "dev:turbopack": "cross-env NODE_ENV=development next dev --turbopack",
    "build": "cross-env NODE_ENV=production SKIP_DB_CONNECTION=true npx next build",
    "build:dev": "cross-env NODE_ENV=development SKIP_DB_CONNECTION=true npx next build --turbopack",
    "build:prod": "cross-env NODE_ENV=production SKIP_DB_CONNECTION=true npx next build",
    "start": "node scripts/start-standalone.js",
    "start:dev": "npm run dev",
    "start:prod": "node scripts/start-standalone.js",
    "install:selfhost": "bash scripts/install.sh",
    "install:docker": "bash scripts/install.sh",
    "install:local": "bash scripts/install-local.sh",
    "doctor": "bash scripts/doctor.sh",
    "scan:public": "node scripts/scan-public-release.js --tracked",
    "export:public": "node scripts/prepare-public-export.js",
    "verify:public": "node scripts/check-public-export.js",
    "lint": "eslint",
    "audit:dependencies": "npm audit --audit-level=high",
    "test:security": "node --test tests/security/*.test.mjs",
    "test:parity": "node scripts/check-security-parity.mjs",
    "test:api-tokens": "node scripts/test-api-token-security.js",
    "test:api-tokens:db": "node scripts/test-api-token-db.js",
    "test:admin-policy": "node scripts/test-admin-policy.js",
    "test:workflow": "node scripts/test-workflow-condition.js",
    "test:screen-security": "node scripts/test-screen-security.js",
    "test:ollama": "node scripts/test-ollama-endpoints.js",
    "smoke": "node scripts/smoke-routes.js",
    "check:production": "node scripts/check-production-install.js",
    "react:doctor": "react-doctor",
    "test:local-release": "node scripts/check-local-release.js",
    "test:docker-config": "node --test tests/docker-e2e-config.test.cjs && node scripts/check-docker-install.js --validate-only",
    "test:docker-install": "node scripts/check-docker-install.js",
    "mock-ollama": "node scripts/mock-ollama.js",
    "create-admin": "node scripts/create-admin.js",
    "create-admin:interactive": "node scripts/create-admin.js --interactive",
    "setup-postgres": "node scripts/create-postgres-schema.js",
    "test-postgres": "node scripts/test-postgres-connection.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/postcss": "^4",
    "@uiw/react-markdown-preview": "^5.1.5",
    "@uiw/react-md-editor": "^4.0.8",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.542.0",
    "next": "15.5.20",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "recharts": "^3.2.0",
    "rehype-sanitize": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "winston": "3.17.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "react-doctor": "^0.7.6",
    "react-grab": "^0.1.48",
    "react-scan": "^0.5.7",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "packageManager": "npm@10.8.2"
}

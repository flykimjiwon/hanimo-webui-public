# hanimo-webui Environment Configuration
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ─── Required ───────────────────────────────────────────────────────────────

# JWT Secret — used to sign authentication tokens
# Generate a secure secret with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here

# One-time proof required by the first-admin setup screen.
# scripts/install.sh and scripts/install-local.sh generate this automatically.
HANIMO_SETUP_TOKEN=your-setup-token-here

# AES-256-GCM key for encrypting user-configured provider credentials.
# scripts/install.sh generates this automatically.
HANIMO_CREDENTIAL_ENCRYPTION_KEY=your-credential-encryption-key-here

# PostgreSQL Connection
# Format: postgresql://user:password@host:port/database
POSTGRES_URI=postgresql://hanimo-webui:your-password@127.0.0.1:5432/hanimo-webui

# Docker Compose database defaults. scripts/install.sh replaces the password.
POSTGRES_USER=hanimo
POSTGRES_PASSWORD=change-me-after-install
POSTGRES_DB=hanimo

# Initial admin account. scripts/install.sh and scripts/install-local.sh generate
# a strong password when this value is missing or left as the placeholder.
HANIMO_ADMIN_EMAIL=admin@hanimo.ai
HANIMO_ADMIN_PASSWORD=change-me-after-install
HANIMO_ADMIN_NAME=System Administrator
HANIMO_ADMIN_DEPARTMENT=Hanimo
HANIMO_ADMIN_TEAM=Admin Team

# ─── Optional ───────────────────────────────────────────────────────────────

# Timezone (defaults to UTC)
TZ=UTC

# Dev server port (defaults to 3000)
PORT=3000

# Destructive database maintenance routes stay disabled by default.
# Enable only for a trusted local maintenance window.
HANIMO_ENABLE_DESTRUCTIVE_ADMIN=false

# Experimental Workflow, Screen, RAG, MCP, Community, and agent routes are
# unavailable by default. Enable only when you accept their Labs support scope.
HANIMO_ENABLE_LABS=false

# Browser origin and authentication abuse controls.
# Set HANIMO_PUBLIC_URL when requests reach the app through a reverse proxy.
# HANIMO_ALLOWED_ORIGINS accepts additional comma-separated browser origins.
HANIMO_PUBLIC_URL=http://localhost:3000
# HANIMO_ALLOWED_ORIGINS=https://chat.example.com
HANIMO_TRUST_PROXY=false
HANIMO_TRUST_PROXY_HOPS=1

# Provider requests may legitimately run longer than ordinary outbound checks.
HANIMO_PROVIDER_TIMEOUT_MS=600000
# Exact private-LAN provider hostnames/IPs, comma-separated (no scheme, port, CIDR, or wildcard).
HANIMO_PROVIDER_LOCAL_ALLOWLIST=
HANIMO_AUTH_RATE_LIMIT_MAX=10
HANIMO_AUTH_RATE_LIMIT_DISTRIBUTED_MAX=100
HANIMO_AUTH_RATE_LIMIT_CLIENT_MAX=300
HANIMO_AUTH_RATE_LIMIT_WINDOW_MS=900000

# ─── OAuth / SSO (only needed if using SSO login) ───────────────────────────

# OAUTH_URL=https://your-oauth-provider.com
# OAUTH_COMPANY_CODE=YOUR_ORG_CODE
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_AUTH_PATH=/oauth/authorize

# ─── Model Server Timeouts (milliseconds) ───────────────────────────────────

# Streaming response timeout (default: 900000 = 15 min)
# MODEL_SERVER_TIMEOUT_STREAM=900000

# Normal response timeout (default: 600000 = 10 min)
# MODEL_SERVER_TIMEOUT_NORMAL=600000

# Retry delay on failure (default: 1000 = 1 sec)
# MODEL_SERVER_RETRY_DELAY=1000
